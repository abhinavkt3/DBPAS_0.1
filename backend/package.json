{
  "name": "dbpas-backend",
  "version": "1.0.0",
  "description": "DBPAS - Decentralized Product Authentication System Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --verbose --forceExit",
    "test:unit": "jest --testPathPattern=tests/unit --verbose",
    "test:integration": "jest --testPathPattern=tests/integration --verbose",
    "test:adversarial": "jest --testPathPattern=tests/adversarial --verbose",
    "test:benchmark": "jest --testPathPattern=tests/benchmark --verbose --detectOpenHandles",
    "seed": "node scripts/seed-data.js"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
